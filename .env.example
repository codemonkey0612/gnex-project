# ============================================
# G-NEX Platform Environment Variables
# ============================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=G-NEX

# Database
# Option 1: Prisma Dev (local embedded PostgreSQL) - run `npx prisma dev` first
# DATABASE_URL=prisma+postgres://localhost:51213/?api_key=...
# DIRECT_DATABASE_URL=postgres://postgres:postgres@localhost:51214/template1?sslmode=disable
#
# Option 2: Supabase
# DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=...
# DIRECT_DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# Option 3: Direct PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/gnex_dev
# DIRECT_DATABASE_URL=postgresql://user:password@localhost:5432/gnex_dev
DATABASE_URL=postgresql://user:password@localhost:5432/gnex_dev
DIRECT_DATABASE_URL=postgresql://user:password@localhost:5432/gnex_dev

# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# AWS S3 (Image/File Storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-northeast-1
AWS_S3_BUCKET_NAME=gnex-uploads

# Stripe (Payment - Lead Purchase)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Email (Notification)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@gnex.jp
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@gnex.jp
